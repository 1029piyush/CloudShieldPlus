# ==========================================
# CloudIntercept Environment Configuration Example
# ==========================================

# 1. Database Configuration (Shared by db and backend services)
DB_USER=postgres
DB_PASSWORD=your_secure_postgres_password
DB_NAME=cloudshield

# 2. Flask Backend Secrets (Must be secure, random keys in production)
JWT_SECRET=your_jwt_signing_key_secret_here
SECRET_KEY=your_flask_session_secret_key_here
FERNET_KEY=your_base64_aes_fernet_symmetrical_key_here

# 3. Google OAuth Configurations (Obtained from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_for_backend_here
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_for_client_here
